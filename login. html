<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SurveyIN - Login</title>
    <style>
        /* --- CSS INTERNAL --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f7cbd7; /* Warna pink latar belakang */
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Tombol Back di area atas */
        .top-section {
            padding: 30px 20px;
            height: 150px;
        }

        .back-button {
            text-decoration: none;
            color: #1150ab; /* Biru Navy */
            font-weight: 900;
            font-size: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: 'Georgia', serif;
        }

        /* Kartu Login Putih */
        .login-container {
            background-color: #ffffff;
            border-top-left-radius: 40px;
            border-top-right-radius: 40px;
            flex: 1;
            padding: 40px 30px;
            display: flex;
            flex-direction: column;
            align-items: center;
            box-shadow: 0 -5px 15px rgba(0,0,0,0.05);
        }

        .login-title {
            color: #1150ab;
            font-family: 'Georgia', serif;
            font-size: 32px;
            margin-bottom: 40px;
            letter-spacing: 1px;
        }

        /* Form Styling */
        .form-wrapper {
            width: 100%;
            max-width: 400px;
        }

        .input-box {
            border: 2px solid #000000;
            display: flex;
            align-items: center;
            padding: 15px;
            margin-bottom: 20px;
            height: 70px;
        }

        .icon-placeholder {
            font-size: 35px;
            margin-right: 15px;
            color: #000;
            display: flex;
            align-items: center;
        }

        .input-box input {
            border: none;
            outline: none;
            width: 100%;
            font-size: 18px;
            font-weight: bold;
            color: #1150ab;
            text-transform: uppercase;
        }

        .input-box input::placeholder {
            color: #1150ab;
            opacity: 0.7;
        }

        /* Tombol Login (Pindah ke index.html) */
        .btn-login {
            background-color: #1150ab;
            color: #ffffff;
            text-decoration: none;
            display: block;
            width: fit-content;
            margin: 20px auto;
            padding: 12px 60px;
            border-radius: 30px;
            font-weight: bold;
            font-size: 18px;
            text-align: center;
            transition: 0.3s;
        }

        .btn-login:hover {
            background-color: #0a369d;
            transform: scale(1.05);
        }

        /* Social Media Section */
        .social-section {
            text-align: center;
            margin-top: 30px;
        }

        .social-text {
            color: #1150ab;
            font-weight: bold;
            font-size: 20px;
            margin-bottom: 20px;
        }

        .social-icons {
            display: flex;
            justify-content: center;
            gap: 25px;
        }

        .s-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-weight: bold;
            font-size: 24px;
        }

        .fb { background-color: #1877F2; color: white; }
        .gl { background-color: #ffffff; color: #EA4335; border: 1px solid #ddd; }
        .ap { background-color: #000000; color: white; }

    </style>
</head>
<body>

    <div class="top-section">
        <a href="index.html" class="back-button">
            <span>&#10094;</span> BACK
        </a>
    </div>

    <div class="login-container">
        <h1 class="login-title">LOGIN</h1>

        <div class="form-wrapper">
            <div class="input-box">
                <span class="icon-placeholder">&#128100;</span>
                <input type="text" placeholder="ENTER EMAIL">
            </div>

            <div class="input-box">
                <span class="icon-placeholder">&#128065;&#10005;</span>
                <input type="password" placeholder="PASSWORD">
            </div>

            <a href="index.html" class="btn-login">LOGIN</a>
        </div>

        <div class="social-section">
            <p class="social-text">Sign in with</p>
            <div class="social-icons">
                <a href="#" class="s-icon fb">f</a>
                <a href="#" class="s-icon gl">G</a>
                <a href="#" class="s-icon ap">&#63111;</a>
            </div>
        </div>
    </div>

</body>
</html>
